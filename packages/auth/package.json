{
  "name": "@shein/auth",
  "version": "0.1.0",
  "private": true,
  "description": "Núcleo de autenticación compartido (agnóstico de framework): hashing bcrypt, tokens JWT (jose) y tipos de sesión.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
