{
  "name": "shein-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo del ecosistema SHEIN: panel admin, app móvil y tienda online sobre una base tecnológica compartida.",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "npm run db:generate -w @shein/database",
    "db:push": "npm run db:push -w @shein/database",
    "db:migrate": "npm run db:migrate -w @shein/database",
    "db:seed": "npm run db:seed -w @shein/database",
    "db:studio": "npm run db:studio -w @shein/database"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3"
  }
}
