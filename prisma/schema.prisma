// ============================================================
//  Administrador de Inventario - SHEIN Mystery Boxes
//  Prisma Schema
//
//  Principio central: cada prenda es ÚNICA. No existe stock
//  múltiple. Cada prenda es un registro independiente (Product).
//  Nada se elimina físicamente: se archiva y se audita.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Conexión de la app (pooler de transacciones / pgbouncer).
  url       = env("DATABASE_URL")
  // Conexión directa para migraciones (sin pgbouncer).
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------------
//  ENUMS
// ------------------------------------------------------------

enum Role {
  ADMIN
  EMPLOYEE
}

enum Gender {
  WOMAN
  MAN
  KID
}

enum ProductStatus {
  AVAILABLE
  RESERVED
  SOLD
  ARCHIVED
}

enum SaleChannel {
  LOCAL
  ONLINE
  PARTICULAR
}

// Tipo de acción registrada en la auditoría.
enum AuditAction {
  CREATE
  UPDATE
  STATUS_CHANGE
  PRICE_CHANGE
  SELL
  ARCHIVE
  RESTORE
  LOGIN
  LOGOUT
  IMPORT
}

// Entidad afectada por una acción de auditoría.
enum AuditEntity {
  PRODUCT
  SALE
  USER
  CATEGORY
  TAG
  SESSION
}

// ------------------------------------------------------------
//  USUARIOS
// ------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(EMPLOYEE)
  isActive  Boolean  @default(true)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones (un usuario es responsable de sus acciones)
  createdProducts Product[]  @relation("ProductCreatedBy")
  updatedProducts Product[]  @relation("ProductUpdatedBy")
  sales           Sale[]     @relation("SaleRegisteredBy")
  auditLogs       AuditLog[] @relation("AuditActor")

  @@index([email])
  @@index([role])
}

// ------------------------------------------------------------
//  CATEGORÍAS / SUBCATEGORÍAS
//  (Mujer/Hombre/Niño -> Remeras, Buzos, Camisas, ...)
// ------------------------------------------------------------

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories Subcategory[]
  products      Product[]

  @@index([slug])
}

model Subcategory {
  id         String   @id @default(cuid())
  name       String
  slug       String
  order      Int      @default(0)
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id])
  products Product[]

  @@unique([categoryId, slug])
  @@index([categoryId])
}

// ------------------------------------------------------------
//  PRODUCTO (la prenda única)
// ------------------------------------------------------------

model Product {
  id            String        @id @default(cuid())
  // Código interno legible y único (ej: SHN-000123)
  internalCode  String        @unique
  name          String
  description   String?       @db.Text
  gender        Gender
  size          String
  // Precio de lista en centavos para evitar errores de coma flotante.
  priceCents    Int
  status        ProductStatus @default(AVAILABLE)

  categoryId    String
  subcategoryId String
  createdById   String
  updatedById   String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  // Fecha de ingreso al inventario (puede diferir de createdAt en importaciones)
  intakeAt      DateTime      @default(now())

  category      Category      @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory   @relation(fields: [subcategoryId], references: [id])
  createdBy     User          @relation("ProductCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?         @relation("ProductUpdatedBy", fields: [updatedById], references: [id])

  images        ProductImage[]
  tags          ProductTag[]
  sale          Sale?

  @@index([status])
  @@index([gender])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([createdById])
  @@index([internalCode])
  @@index([createdAt])
}

// ------------------------------------------------------------
//  IMÁGENES (múltiples por prenda, ordenables, principal)
// ------------------------------------------------------------

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  order     Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ------------------------------------------------------------
//  ETIQUETAS (N:M) - Oversize, Vintage, Y2K, ...
// ------------------------------------------------------------

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String?
  createdAt DateTime @default(now())

  products ProductTag[]

  @@index([slug])
}

model ProductTag {
  productId String
  tagId     String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
}

// ------------------------------------------------------------
//  VENTA (1:1 con la prenda vendida, nunca se elimina)
// ------------------------------------------------------------

model Sale {
  id             String      @id @default(cuid())
  productId      String      @unique
  channel        SaleChannel
  sellerName     String
  // Precio final real de venta, en centavos.
  finalPriceCents Int
  notes          String?     @db.Text
  soldAt         DateTime    @default(now())
  registeredById String
  createdAt      DateTime    @default(now())

  product      Product @relation(fields: [productId], references: [id])
  registeredBy User    @relation("SaleRegisteredBy", fields: [registeredById], references: [id])

  @@index([channel])
  @@index([soldAt])
  @@index([registeredById])
}

// ------------------------------------------------------------
//  AUDITORÍA (registro inmutable de todas las acciones)
//  Guarda: quién, qué, cuándo y el diff (antes/después).
//
//  Es polimórfica: `entity` + `entityId` identifican el objeto
//  afectado (Product, Sale, User, ...). No usa FK para poder
//  registrar cualquier entidad de forma uniforme y perdurable.
// ------------------------------------------------------------

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  entity    AuditEntity
  entityId  String
  // Resumen legible de la acción (ej: "Precio: $10.000 -> $8.000")
  summary   String
  // Snapshot del cambio en formato JSON { before, after }
  changes   Json?
  actorId   String
  createdAt DateTime    @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@index([action])
}
