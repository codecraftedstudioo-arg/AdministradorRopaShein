# ----------------------------------------------------------------
# Base de datos PostgreSQL
#
# Local:  DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shein_admin?schema=public"
#
# Supabase (recomendado): usar el Transaction pooler (6543) para la app
# y el Session pooler / Direct (5432) para migraciones (DIRECT_URL).
# ----------------------------------------------------------------
# Elegí según cómo corras la app:
#  - Server persistente (next dev / next start, VPS): Session pooler (5432),
#    conexiones tibias. connection_limit ~10.
#  - Serverless (Vercel functions): Transaction pooler (6543) con
#    ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?connection_limit=10&pool_timeout=30&sslmode=require"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# ----------------------------------------------------------------
# Autenticación
# Generar un secreto seguro con:  openssl rand -base64 32
# ----------------------------------------------------------------
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Duración de la sesión (en días)
SESSION_MAX_AGE_DAYS="7"

# ----------------------------------------------------------------
# App
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="SHEIN Inventory"
# Carpeta pública para imágenes subidas (dev). En producción usar S3/UploadThing.
UPLOAD_DIR="public/uploads"
