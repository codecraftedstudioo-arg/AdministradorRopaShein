    "./config": "./src/config.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "jose": "^6.1.0"
  },
  "devDependencies": {
